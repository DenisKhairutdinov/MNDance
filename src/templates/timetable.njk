    <div class="timetable__controls" data-timetable-controls>
      <button
        class="prev-button"
        type="button"
        aria-label="Предыдущий слайд"
        aria-controls="timetable-wrapper"
        aria-disabled="true"
        disabled
        data-timetable-button
      >
        <svg class="prev-button__icon" aria-hidden="true">
          <use href="#icon-arrow-prev"></use>
        </svg>
      </button>
      <div class="timetable__dots" data-timetable-dots>
        <div class="timetable__dot timetable__dot--is-active"></div>
        <div class="timetable__dot"></div>
      </div>
      <button
        class="next-button next-button--is-active"
        type="button"
        aria-label="Следующий слайд"
        aria-controls="timetable-wrapper"
        aria-disabled="false"
        data-timetable-button
      >
        <svg class="next-button__icon" aria-hidden="true">
          <use href="#icon-arrow-next"></use>
        </svg>
      </button>
