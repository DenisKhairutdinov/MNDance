  <div class="timetable__annotation">
    <p class="timetable__text"><span class="bold">д</span> - детская группа</p>
    <p class="timetable__text"><span class="bold">н</span> - начальная группа</p>
    <p class="timetable__text"><span class="bold">п</span> - продвинутая группа</p>
    <p class="timetable__text"><span class="bold">б</span> - большой зал</p>
    <p class="timetable__text"><span class="bold">м</span> - малый зал</p>
