    </div>
    <div class="dance-styles__controls">
      <button
        class="prev-button next-button--is-active"
        type="button"
        aria-label="Предыдущий слайд"
        aria-controls=""
        aria-disabled="true"
        data-dance-styles-prev-button
      >
        <svg class="prev-button__icon" aria-hidden="true">
          <use href="#icon-arrow-prev"></use>
        </svg>
      </button>
      <div class="dance-styles__dots" data-dance-styles-dots>
        <div class="dance-styles__dot"></div>
        <div class="dance-styles__dot"></div>
        <div class="dance-styles__dot dance-styles__dot--is-active"></div>
        <div class="dance-styles__dot"></div>
        <div class="dance-styles__dot"></div>
      </div>
      <button
        class="next-button next-button--is-active"
        type="button"
        aria-label="Следующий слайд"
        aria-controls=""
        aria-disabled="false"
        data-dance-styles-next-button
      >
        <svg class="next-button__icon" aria-hidden="true">
          <use href="#icon-arrow-next"></use>
        </svg>
      </button>
