<section
  id="dance-styles"
  class="dance-styles container"
  data-dance-styles-container
  data-fade-section
>
  <h2 class="dance-styles__title">Стили</h2>

  <div class="dance-styles__carousel" data-carousel>
    <div class="dance-styles__carousel-viewport" data-carousel-viewport>
      <ul class="dance-styles__list" data-carousel-slides>
        <li class="dance-styles__item" data-carousel-slide>
          <article class="dance-style">
            <div class="dance-style__inner">
              <picture class="dance-style__image-wrapper">
                <source srcset="/src/assets/images/dance-styles/contemp.webp" type="image/webp" />
                <img
                  class="dance-style__image"
                  src="/src/assets/images/dance-styles/contemp.png"
                  alt="Танец контемп"
                  decoding="async"
                  loading="lazy"
                />
              </picture>
              <div class="dance-style__wrapper">
                <h2 class="dance-style__title">Контемп</h2>
                <ul class="dance-style__list">
                  <li class="dance-style__item">уровень: <span class="accent">средний</span></li>
                  <li class="dance-style__item">ритм: <span class="accent">свободный</span></li>
                  <li class="dance-style__item">энергия: <span class="accent">3 / 5</span></li>
                </ul>
                <p class="dance-style__description">
                  Выразительный и эмоциональный стиль, часто используется в сольных постановках.
                  Темп меняется по ходу.
                </p>
              </div>
            </div>
          </article>
        </li>
        <li class="dance-styles__item" data-carousel-slide>
          <article class="dance-style">
            <div class="dance-style__inner">
              <picture class="dance-style__image-wrapper">
                <source
                  srcset="/src/assets/images/dance-styles/breakdance.webp"
                  type="image/webp"
                />
                <img
                  class="dance-style__image"
                  src="/src/assets/images/dance-styles/breakdance.png"
                  alt="Танец контемп"
                  decoding="async"
                  loading="lazy"
                />
              </picture>
              <div class="dance-style__wrapper">
                <h2 class="dance-style__title">Брейкданс</h2>
                <ul class="dance-style__list">
                  <li class="dance-style__item">уровень: <span class="accent">профи</span></li>
                  <li class="dance-style__item">ритм: <span class="accent">активный</span></li>
                  <li class="dance-style__item">энергия: <span class="accent">5 / 5</span></li>
                </ul>
                <p class="dance-style__description">
                  Самый атлетичный стиль. Много акробатики, силовых элементов и батловой энергии. Не
                  для слабонервных.
                </p>
              </div>
            </div>
          </article>
        </li>
        <li class="dance-styles__item" data-carousel-slide>
          <article class="dance-style">
            <div class="dance-style__inner">
              <picture class="dance-style__image-wrapper">
                <source srcset="/src/assets/images/dance-styles/popping.webp" type="image/webp" />
                <img
                  class="dance-style__image"
                  src="/src/assets/images/dance-styles/popping.png"
                  alt="Танец поппинг"
                  decoding="async"
                  loading="lazy"
