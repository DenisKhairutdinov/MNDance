<section id="hero" class="hero">
  <div class="hero__background"></div>
  <div class="hero__wrapper">
    <p class="hero__slogan">Выходи<br />за границы<br />привычного.<br />Танцуй!</p>
    <div class="hero__title-wrapper">
      <h1 class="hero__title">Студия современного танца в Челябинске.</h1>
      <p class="hero__subtitle">Первое пробное занятие — бесплатно!</p>
    </div>

    <button
      class="join-button hero__join-button"
      type="button"
      aria-expanded="false"
      aria-haspopup="dialog"
      aria-controls="join-modal"
      data-event-button
      data-pub-event="join-modal: open-request"
      data-sub-event="join-modal: close"
    >
      <svg class="join-button__icon" aria-hidden="true">
        <use href="#icon-join"></use>
      </svg>
      <span class="join-button__text">Присоединиться</span>
    </button>
    <picture class="hero__image-wrapper">
      <source srcset="/src/assets/images/hero/hero.webp" type="image/webp" />
      <img
        class="hero__image"
        src="/src/assets/images/hero/hero.png"
        alt="Девушка танцует в современном стиле"
        decoding="sync"
      />
    </picture>
    <div class="socials hero__socials">
      <a
        href="https://vk.ru/"
        class="socials__link socials__link--white-bg"
        aria-label="Перейти в сообщество во Вконтакте"
        target="_blank"
        rel="noopener"
      >
        <svg class="socials__icon" aria-hidden="true">
          <use href="#icon-vk"></use>
        </svg>
      </a>
      <a
        href="https://web.telegram.org/"
        class="socials__link socials__link--white-bg"
        aria-label="Перейти в сообщество в Телеграме"
        target="_blank"
        rel="noopener"
      >
        <svg class="socials__icon" aria-hidden="true">
          <use href="#icon-tg"></use>
        </svg>
      </a>
      <a
        href="https://www.instagram.com/"
        class="socials__link socials__link--white-bg"
        aria-label="Перейти в сообщество в Инстаграме"
        target="_blank"
        rel="noopener"
      >
        <svg class="socials__icon" aria-hidden="true">
          <use href="#icon-inst"></use>
        </svg>
      </a>
    </div>
  </div>
</section>
