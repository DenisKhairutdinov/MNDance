<header class="header">
  <div class="header__wrapper">
    <a href="#hero" class="logo" aria-label="На главный экран" data-local-link>
      <svg class="logo__icon" aria-hidden="true">
        <use href="#icon-logo"></use>
      </svg>
    </a>
    <nav class="menu" aria-label="Основная навигация">
      <button
        class="menu-button menu__button"
        type="button"
        aria-controls="menu"
        aria-expanded="false"
        aria-label="Открыть меню"
        data-menu-button
      >
        <svg
          class="menu__icon"
          aria-hidden="true"
          width="16"
          height="16"
          viewBox="0 0 16 16"
          xmlns="http://www.w3.org/2000/svg"
          data-menu-start-icon
        >
          <path
            d="M13.3333 7.5C13.6095 7.5 13.8333 7.72386 13.8333 8C13.8333 8.27614 13.6095 8.5 13.3333 8.5H2.66667C2.39052 8.5 2.16667 8.27614 2.16667 8C2.16667 7.72386 2.39052 7.5 2.66667 7.5H13.3333Z"
          />
