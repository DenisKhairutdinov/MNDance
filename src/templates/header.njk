            d="M13.3333 11.5C13.6095 11.5 13.8333 11.7239 13.8333 12C13.8333 12.2761 13.6095 12.5 13.3333 12.5H2.66667C2.39052 12.5 2.16667 12.2761 2.16667 12C2.16667 11.7239 2.39052 11.5 2.66667 11.5H13.3333Z"
          />
